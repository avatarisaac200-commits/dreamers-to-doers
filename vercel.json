      "destination": "/facilitators.html"
    },
    {
      "source": "/host",
      "destination": "/convener.html"
    },
    {
      "source": "/host/",
      "destination": "/convener.html"
    },
    {
      "source": "/Host",
      "destination": "/convener.html"
    },
    {
      "source": "/Host/",
      "destination": "/convener.html"
    },
    {
      "source": "/Convener",
      "destination": "/convener.html"
    },
    {
      "source": "/Convener/",
      "destination": "/convener.html"
    },
    {
      "source": "/convener",
      "destination": "/convener.html"
    },
    {
      "source": "/convener/",
      "destination": "/convener.html"
    },
    {
      "source": "/covener",
      "destination": "/convener.html"
    },
    {
      "source": "/covener/",
      "destination": "/convener.html"
    },
    {
      "source": "/impact-footprints",
      "destination": "/impact-footprints.html"
    },
    {
      "source": "/impact-footprints/",
      "destination": "/impact-footprints.html"
    }
  ]
