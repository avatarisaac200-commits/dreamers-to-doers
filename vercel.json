{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/impact-footprints",
      "destination": "/api/impact-footprints.js"
    },
    {
      "source": "/api/covener-impact-footprints",
      "destination": "/api/covener-impact-footprints.js"
    },
    {
      "source": "/api/convener-impact-footprints",
      "destination": "/api/convener-impact-footprints.js"
    },
    {
      "source": "/api/host-impact-footprints",
      "destination": "/api/host-impact-footprints.js"
    },
    {
      "source": "/",
      "destination": "/api/site?path="
    },
    {
      "source": "^/(?!api/)(.*)$",
      "destination": "/api/site?path=$1"
    }
  ],
  "functions": {
    "api/impact-footprints.js": {
      "includeFiles": "facilitators/Impact-footprints/**"
    },
    "api/covener-impact-footprints.js": {
      "includeFiles": "facilitators/Impact-footprints/**"
    },
    "api/convener-impact-footprints.js": {
      "includeFiles": "facilitators/Impact-footprints/**"
    },
    "api/host-impact-footprints.js": {
      "includeFiles": "facilitators/Impact-footprints/**"
    },
    "api/site.js": {
      "includeFiles": "**/*"
    }
  }
}
