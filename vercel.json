{
  "cleanUrls": false,
  "functions": {
    "api/impact-footprints.js": {
      "includeFiles": "facilitators/Impact-footprints/**"
    },
    "api/covener-impact-footprints.js": {
      "includeFiles": "facilitators/Impact-footprints/**"
    }
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/facilitators",
      "destination": "/facilitators.html"
    },
    {
      "source": "/facilitators/",
      "destination": "/facilitators.html"
    },
    {
      "source": "/covener",
      "destination": "/covener.html"
    },
    {
      "source": "/covener/",
      "destination": "/covener.html"
    },
    {
      "source": "/impact-footprints",
      "destination": "/impact-footprints.html"
    },
    {
      "source": "/impact-footprints/",
      "destination": "/impact-footprints.html"
    }
  ]
}
